FROM node:22-alpine

# Enable pnpm
RUN corepack enable && corepack prepare pnpm@10.14.0 --activate

WORKDIR /app

# Copy toàn bộ workspace files trước
COPY . .

# Install dependencies
RUN pnpm install --frozen-lockfile

# Expose port
EXPOSE 5174

# Start dev server with hot reload
CMD ["pnpm", "--filter", "@engilink/company", "run", "dev", "--host", "0.0.0.0"]